# Exemple d'environnement (copier en `.env` si vous voulez).
#
# Pour les besoins du TP, une clé de chiffrement par défaut est fournie dans
# docker-compose.yml si cette variable n'est pas définie.



MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=devsecops
MYSQL_PASSWORD=devsecops
MYSQL_DB=devsecops

# Utilisé pour chiffrer les notes côté application.
# Format attendu : clé Fernet (base64 url-safe 32 bytes).
FLASK_SECRET_KEY=une_grosse_cle_random
DATA_ENCRYPTION_KEY=a3abommRjf7J0NEjbTo49gYNORTxQTeP1JiE_lPhnJo=

